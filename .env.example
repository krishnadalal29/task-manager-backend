# Environment variables for the Task Manager backend application
NODE_ENV=

#DATABASE CONFIGURATION
PORT=
MONGO_HOST=
MONGO_PORT=
MONGO_DB=
# Uncomment and set the following values if using authentication:
# MONGO_USERNAME=
# MONGO_PASSWORD=
# MONGO_AUTH_SOURCE=
# Or use a full MongoDB URI instead of individual values:
# MONGO_URI=

# Google OAuth 2.0 configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_REDIRECT_URL=
GOOGLE_AUTH_ENDPOINT=
GOOGLE_TOKEN_ENDPOINT=
GOOGLE_USERINFO_ENDPOINT=