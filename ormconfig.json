{
    "type": "mongodb",
    "host": "localhost",
    "database": "myapp",
    "port": 27017,
    "useNewUrlParser": true,
    "useUnifiedTopology": true,
    "synchronize": true,
    "logging": false,
    "entities": [
        "dist/entity/*.js"
    ],
    "migrations": [
        "dist/entity/*.js"
    ],
    "cli": {
        "entitiesDir": "src/entity"
    }
}
